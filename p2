import gensim.downloader as api
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA

model = api.load('word2vec-google-news-300')

# 10 technology-related words
tech_words = ['computer','internet','software','hardware','network',
              'data','server','database','programming','algorithm']

vectors = [model[w] for w in tech_words]

# Reduce to 2D with PCA
reduced = PCA(n_components=2).fit_transform(vectors)

# Plot
plt.figure(figsize=(8, 6))
for i, word in enumerate(tech_words):
    plt.scatter(reduced[i, 0], reduced[i, 1], color='blue')
    plt.text(reduced[i, 0] + 0.02, reduced[i, 1] + 0.02, word, fontsize=12)
plt.title('2D PCA Projection of Technology Word Embeddings')
plt.xlabel('PCA Component 1')
plt.ylabel('PCA Component 2')
plt.grid(True)
plt.show()

# Generate 5 similar words for a given input
def generate_similar_words(word, topn=5):
    try:
        similar = model.most_similar(positive=[word], topn=topn)
        print(f"Top {topn} words similar to '{word}':")
        for w, score in similar:
            print(f'  {w}: {score:.4f}')
    except KeyError:
        print(f"'{word}' not in vocabulary.")

generate_similar_words('internet')
